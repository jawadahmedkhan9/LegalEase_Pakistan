@app.get("/")
async def root():
    return {
        "message": "LegalEase Pakistan API - Enhanced Version",
        "version": "2.0.0",
        "features": [
            "AI-powered query classification",
            "Hybrid search (semantic + keyword)",
            "Adaptive response structure",
            "Enhanced source attribution",
            "Multi-collection search"
        ],
        "status": "active"
    }

@app.post("/chat", response_model=ChatResponse)
async def chat_endpoint(request: ChatRequest):
    """
    Enhanced chat endpoint with AI classification and adaptive responses
    """
    try:
        # Step 1: Classify query with AI
        classification = classify_query_with_ai(request.message)
        print(f"Query classified as: {classification}")
        
        # Step 2: Fetch context with hybrid search
        context_data = fetch_relevant_context_enhanced(
            query=request.message,
            classification=classification,
            top_k=10
        )
        
        # Step 3: Generate adaptive response
        response = generate_adaptive_response(
            query=request.message,
            context_data=context_data,
            classification=classification,
            conversation_history=request.conversation_history
        )
        
        return ChatResponse(
            response=response,
            sources=context_data.get("sources", []),
            collections_used=context_data.get("collections_searched", []),
            status="success"
        )
        
    except Exception as e:
        print(f"Chat endpoint error: {e}")
        raise HTTPException(status_code=500, detail=str(e))

@app.post("/analyze-contract")
async def analyze_contract(file: UploadFile = File(...)):
    try:
        file_content = await file.read()
        
        if file.content_type == "application/pdf":
            contract_text = extract_text_from_pdf(file_content)
        elif file.content_type in ["application/vnd.openxmlformats-officedocument.wordprocessingml.document", "application/msword"]:
            contract_text = extract_text_from_docx(file_content)
        elif file.content_type == "text/plain":
            contract_text = file_content.decode("utf-8")
        else:
            raise HTTPException(status_code=400, detail="Unsupported file type")
        
        analysis = analyze_contract_text(contract_text)
        return analysis
        
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@app.get("/health")
async def health_check():
    """Health check endpoint"""
    client_db = get_chroma_client()
    collections_count = len(client_db.list_collections()) if client_db else 0
    
    return {
        "status": "healthy",
        "timestamp": datetime.now().isoformat(),
        "version": "2.0.0",
        "database_connected": client_db is not None,
        "collections_available": collections_count
    }

@app.get("/collections")
async def list_collections():
    """List all available law collections"""
    client_db = get_chroma_client()
    if not client_db:
        raise HTTPException(status_code=500, detail="Database connection error")
    
    collections = client_db.list_collections()
    return {
        "collections": [
            {
                "name": col.name,
                "count": col.count()
            }
            for col in collections
        ]
    }

# Serve static files (for production)
if os.path.exists("build"):
    app.mount("/", StaticFiles(directory="build", html=True), name="static")

if __name__ == "__main__":
    uvicorn.run(
        "App:app",
        host="0.0.0.0",
        port=8000,
        reload=True,
        log_level="info"
    )