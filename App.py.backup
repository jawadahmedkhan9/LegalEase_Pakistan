# CONTRACT ANALYSIS (UNCHANGED)
# ============================================================================

def extract_text_from_pdf(file_content: bytes) -> str:
    """Extract text from PDF file"""
    try:
        pdf_file = io.BytesIO(file_content)
        reader = PyPDF2.PdfReader(pdf_file)
        text = ""
        for page in reader.pages:
            text += page.extract_text() or ""
        return text
    except Exception as e:
        return f"Error extracting PDF: {str(e)}"

def extract_text_from_docx(file_content: bytes) -> str:
    """Extract text from DOCX file"""
    try:
        docx_file = io.BytesIO(file_content)
        doc = docx.Document(docx_file)
        return "\n".join([para.text for para in doc.paragraphs])
    except Exception as e:
        return f"Error extracting DOCX: {str(e)}"

def analyze_contract_text(contract_text: str) -> ContractAnalysis:
    """Analyze contract text and return structured analysis"""
    contract_prompt = f"""You are LegalEase, an AI legal contract verifier specializing in Pakistani law.
Analyze the following contract strictly under Pakistani law.

Respond with a JSON object:
{{
    "summary": "Brief summary of the contract",
    "risks": ["risk1", "risk2", "risk3"],
    "missing": ["missing clause 1", "missing clause 2"],
    "recommendations": ["recommendation 1", "recommendation 2"],
    "timeline": "Expected timeline for implementation",
    "estimated_cost": "PKR cost estimate"
}}

CONTRACT TEXT:
{contract_text[:6000]}
"""
    
    try:
        response = client.chat.completions.create(
            model="llama-3.1-8b-instant",
            messages=[
                {"role": "system", "content": "You are a legal contract analyzer. Respond only with valid JSON."},
                {"role": "user", "content": contract_prompt}
            ],
            temperature=0.1,
            max_tokens=1000
        )
        
        result = json.loads(response.choices[0].message.content)
        return ContractAnalysis(**result)
    except Exception as e:
        return ContractAnalysis(
            summary="Contract analysis completed with limited data.",
            risks=["Unable to perform detailed risk analysis", "Please consult a legal professional"],
            missing=["Standard Pakistani law compliance clauses may be missing"],
            recommendations=["Review with a Pakistani legal expert", "Ensure compliance with local regulations"],
            timeline="2-4 weeks for professional review",
            estimated_cost="PKR 25,000 - 100,000"
        )

